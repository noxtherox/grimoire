{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Grimoire",
  "version": "0.3.0",
  "identifier": "com.grimoire.notes",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "pnpm cli:dev && pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm cli:bundle"
  },
  "app": {
    "windows": [
      {
        "title": "Grimoire",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "binaries/*"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown document",
        "contentTypes": [
          "net.daringfireball.markdown"
        ],
        "role": "Editor",
        "rank": "Default"
      },
      {
        "ext": [
          "pdf"
        ],
        "name": "PDF document",
        "contentTypes": [
          "com.adobe.pdf"
        ],
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": [
          "doc",
          "docx",
          "rtf",
          "txt",
          "odt",
          "xls",
          "xlsx",
          "csv",
          "ppt",
          "pptx",
          "pages",
          "numbers",
          "key"
        ],
        "name": "Office document",
        "role": "Viewer",
        "rank": "Alternate"
      },
      {
        "ext": [
          "*"
        ],
        "name": "File",
        "contentTypes": [
          "public.data"
        ],
        "role": "Viewer",
        "rank": "Alternate"
      }
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "iOS": {
      "minimumSystemVersion": "16.0",
      "infoPlist": "Info.ios.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3MTFGMjMwMDQ0QTMxQTUKUldTbE1Vb0VNUElSbC9vUWhHM200UWxmR1FZMEU1QjlGL0xtbWJnR0REZFdBSXhMQmpjY3N6VGEK",
      "endpoints": [
        "https://github.com/noxtherox/grimoire/releases/latest/download/latest.json"
      ]
    }
  }
}
