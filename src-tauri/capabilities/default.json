{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "/**" },
        { "path": "$HOME/**" },
        { "path": "**" }
      ]
    },
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "**" },
        { "path": "/**" },
        { "path": "$HOME/**" },
        { "path": "**/.grimoire" },
        { "path": "**/.grimoire/**" },
        { "path": "/**/.grimoire" },
        { "path": "/**/.grimoire/**" },
        { "path": "**/.trash" },
        { "path": "**/.trash/**" },
        { "path": "/**/.trash" },
        { "path": "/**/.trash/**" }
      ]
    }
  ]
}
